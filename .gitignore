# Build artifacts (regenerable)
/scummvm-source/config.h
/scummvm-source/config.mk
/scummvm-source/config.log
/scummvm-source/Makefile
/scummvm-source/scummvm
/scummvm-source/scummvm.exe
/scummvm-source/scummvm.dwp
/scummvm-source/**/*.o
/scummvm-source/**/*.a

# But DO commit win64-build/ binaries (they're our deliverable)
!/win64-build/scummvm.exe
!/win64-build/SDL2.dll
!/win64-build/KYRA.DAT
!/win64-build/ceob.pat

# Test/review outputs (gitignored, regenerated each run)
/test-reports/*.png

# Python cache
__pycache__/
*.pyc

# Logs
*.log

# Temp screenshots from agents
/tmp/
