# Build artifacts (regenerable)
/scummvm-source/config.h
/scummvm-source/config.mk
/scummvm-source/config.log
/scummvm-source/Makefile
/scummvm-source/scummvm
/scummvm-source/scummvm.exe
/scummvm-source/scummvm.dwp
/scummvm-source/**/*.o
/scummvm-source/**/*.a

# But DO commit win64-build/ binaries (they're our deliverable)
!/win64-build/scummvm.exe
!/win64-build/SDL2.dll
!/win64-build/KYRA.DAT
!/win64-build/ceob.pat

# game/ subdir: ignore copyrighted EOB1 game files (EOB.EXE, EOBDATA*.PAK, EYE.PAK, OVL, FNT...)
# Only commit our derivative + setup README
/win64-build/game/*
!/win64-build/game/KYRA.DAT
!/win64-build/game/ceob.pat
!/win64-build/game/TEXT.DAT
!/win64-build/game/README.md
!/win64-build/game/.gitkeep

# Test screenshots ARE committed — they're evidence of the bug-fix loop
# (don't ignore /test-reports/**/*.png)

# Python cache
__pycache__/
*.pyc

# Logs
*.log

# Temp screenshots from agents
/tmp/
